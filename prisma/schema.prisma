generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model products {
  product_id     String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  created_by     String?          @db.VarChar(255)
  updated_at     DateTime?        @default(now()) @db.Timestamp(6)
  updated_by     String?          @db.VarChar(255)
  description    String?
  discount       Decimal?         @db.Decimal(15, 2)
  name           String           @db.VarChar(255)
  price          Decimal          @db.Decimal(15, 2)
  category_id    BigInt
  badge_id       BigInt
  color_id       BigInt?
  product_colors product_colors[]
  product_images product_images[]

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamp(6)
  created_by String?   @db.VarChar(255)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  updated_by String?   @db.VarChar(255)
  is_active  Boolean?  @default(true)
  email      String    @unique @db.VarChar(255)
  name       String?   @db.VarChar(255)
  phone      String?   @db.VarChar(255)
  role       String    @default("user") @db.VarChar(255)

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model badge {
  badge_id   BigInt @id @default(autoincrement())
  badge_name String @db.VarChar

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model category {
  category_id   BigInt @id @default(autoincrement())
  category_name String @unique @db.VarChar

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model product_color_images {
  id             BigInt         @id @default(autoincrement())
  color_id       BigInt
  image_url      String?        @db.VarChar
  product_colors product_colors @relation(fields: [color_id], references: [color_id], onDelete: Cascade)

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model product_colors {
  color_id             BigInt                 @id @default(autoincrement())
  product_id           String                 @db.Uuid
  name                 String?                @db.VarChar
  hex_code             String?                @db.VarChar
  stock                BigInt?
  product_color_images product_color_images[]
  products             products               @relation(fields: [product_id], references: [product_id], onDelete: Cascade)

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model product_images {
  image_id   BigInt   @id @default(autoincrement())
  product_id String   @db.Uuid
  image_url  String?  @db.VarChar
  products   products @relation(fields: [product_id], references: [product_id], onDelete: Cascade)

  @@schema("public")
}
